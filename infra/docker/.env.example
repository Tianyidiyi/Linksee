# ─── 基础设施（infra 层，仅 docker-compose 使用）──────────────────────────────
# MySQL
MYSQL_ROOT_PASSWORD=change_root_password
MYSQL_DATABASE=collab
MYSQL_USER=collab_user
MYSQL_PASSWORD=change_db_password

# Redis
REDIS_PASSWORD=change_redis_password

# MinIO (S3 compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_minio_password

# ─── 应用层（apps/api 使用，不由 docker-compose 注入）──────────────────────────
# 数据库连接串（Prisma DATABASE_URL）
DATABASE_URL=mysql://collab_user:change_db_password@localhost:3306/collab

# Redis 连接串（含密码）
REDIS_URL=redis://:change_redis_password@localhost:6379

# JWT 签名密钥：至少 32 字节随机字符串，不要用可猜测的值
# 生成示例（PowerShell）：-join ((65..90)+(97..122)+(48..57) | Get-Random -Count 48 | ForEach-Object {[char]$_})
JWT_SECRET=change_jwt_secret_min_32_chars_here
JWT_ACCESS_EXPIRES_IN=1800        # 单位秒，30 分钟
JWT_REFRESH_EXPIRES_DAYS=7

# Argon2id 参数（与 auth-design-v1.md §四 保持一致）
ARGON2_MEMORY_COST=65536          # KB，即 64 MB
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# MinIO / S3 对象存储（应用层使用）
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_minio_password
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_DOCS=docs
