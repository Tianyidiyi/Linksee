// ============================================================
// Linksee — Prisma Schema（Auth 组，v2）
// 对应设计文档：docs/api/auth/auth-tables-design-v2.md
//
// 表：users / user_profiles / student_profiles /
//     teacher_profiles / teacher_assistants / assistant_bindings
//
// Refresh Token → Redis（不建表）
// Audit Log     → winston 文件日志（不建表）
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// 枚举：账号角色
// ────────────────────────────────────────────────────────────

enum Role {
  academic  // 教务处
  teacher   // 老师
  assistant // 助教（老师创建的子账号，权限范围绑定到具体课程）
  student   // 学生
}

// ────────────────────────────────────────────────────────────
// users — 鉴权核心，只放每次鉴权都要查的字段
// id = 一卡通号，纯10位数字，自然主键
// ────────────────────────────────────────────────────────────

model User {
  /// 一卡通号，纯10位数字（如 2023010001），系统唯一登录标识
  id                  String   @id @db.VarChar(10)

  /// Argon2id 散列值（含内嵌 salt），原始密码不落库
  passwordHash        String   @db.VarChar(128)

  role                Role
  isActive            Boolean  @default(true)

  /// 批量导入时置 true，首次登录强制改密后置 false
  forceChangePassword Boolean  @default(false)

  createdAt           DateTime @default(now())

  /// 最近一次登录成功时间（登录接口写入）
  lastLoginAt         DateTime?

  /// 最近活跃时间（Socket 心跳更新），用于展示在线状态
  /// 实时 is_online 布尔值存 Redis key=online:{id}，不存 DB
  lastSeenAt          DateTime?

  // 关联
  profile         UserProfile?
  studentProfile  StudentProfile?
  teacherProfile  TeacherProfile?

  assistantBindingsAsAssistant AssistantBinding[] @relation("AssistantUser")

  // 归属关系：老师名下的助教（teacher 侧）；助教归属的老师（assistant 侧）
  teacherAssistantsAsTeacher   TeacherAssistant[] @relation("TeacherOwner")
  teacherAssistantsAsAssistant TeacherAssistant[] @relation("AssistantOwned")

  // Course 模块关联
  createdCourses    Course[]
  courseTeachers    CourseTeacher[]
  courseMembers     CourseMember[]
  createdAssignments Assignment[]
  createdStages     AssignmentStage[]
  groupMemberships  GroupMember[]
  createdGroups     Group[]
  sentGroupJoinRequests GroupJoinRequest[] @relation("JoinRequestApplicant")
  reviewedGroupJoinRequests GroupJoinRequest[] @relation("JoinRequestReviewer")
  sentLeaderTransferRequests GroupLeaderTransferRequest[] @relation("LeaderTransferFrom")
  receivedLeaderTransferRequests GroupLeaderTransferRequest[] @relation("LeaderTransferTo")
  createdMiniTasks  MiniTask[]
  assignedMiniTasks MiniTask[]   @relation("MiniTaskAssignee")
  createdSubmissions Submission[] @relation("SubmissionCreator")
  submittedSubmissions Submission[] @relation("SubmissionSubmitter")
  createdReviews    Review[]      @relation("ReviewAuthor")
  uploadedSubmissionFiles SubmissionFile[] @relation("SubmissionUploader")
  gradedStageGrades StageGrade[]   @relation("StageGradeGrader")
  publishedStageGrades StageGrade[] @relation("StageGradePublisher")
  stageGradeLogs StageGradeLog[]   @relation("StageGradeLogOperator")
  chatConversations ChatConversation[]
  chatMessages      ChatMessage[]
  chatConversationReads ChatConversationRead[]

  @@map("users")
}

// ────────────────────────────────────────────────────────────
// user_profiles — 通用展示信息，所有角色共用
// ────────────────────────────────────────────────────────────

model UserProfile {
  /// FK → users.id（一卡通号）
  userId    String  @id @db.VarChar(10)

  realName  String  @db.VarChar(40)

  /// 学号（学生）或工号（教师/教务），快速展示用
  /// 详细学籍/职工信息在各自的 *_profiles 表中
  accountNo String? @db.VarChar(20)

  /// 头像文件存 MinIO，此处存访问 URL
  avatarUrl String? @db.VarChar(255)

  bio       String? @db.Text

  location  String? @db.VarChar(100)

  /// 选填，用于密码重置通知和系统消息推送
  email     String? @unique @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

// ────────────────────────────────────────────────────────────
// student_profiles — 学生学籍扩展（仅 role=student）
// ────────────────────────────────────────────────────────────

model StudentProfile {
  /// FK → users.id（一卡通号）
  userId String @id @db.VarChar(10)

  /// 教务学籍号（如 202301001）
  /// ⚠️ 与一卡通号 users.id 是两套编号体系，不可混用
  /// 一卡通号是校园卡物理编号，学号是教务系统学籍编号
  stuNo String @unique @db.VarChar(20)

  /// 入学年份（如 2023）
  grade Int @db.SmallInt

  /// 预计毕业年份（如 2027）
  cohort Int @db.SmallInt

  major      String @db.VarChar(60)

  /// 行政班编号（如 软工2301）
  adminClass String @db.VarChar(40)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

// ────────────────────────────────────────────────────────────
// teacher_profiles — 教师学术扩展（仅 role=teacher）
// ────────────────────────────────────────────────────────────

model TeacherProfile {
  /// FK → users.id（一卡通号）
  userId String @id @db.VarChar(10)

  /// 学校人事编号（工号）
  teacherNo String @unique @db.VarChar(20)

  /// 职称（如 教授 / 副教授 / 讲师）
  title String? @db.VarChar(30)

  researchDirection String? @db.VarChar(200)

  college String? @db.VarChar(60)

  /// 学术成果简介
  description String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teacher_profiles")
}

// ────────────────────────────────────────────────────────────
// teacher_assistants — 老师与助教的归属关系
//
// 老师创建助教账号时写入，记录"这个助教账号属于哪位老师"。
// assistantUserId 是 PK，保证一个助教只能属于一个老师。
// 用途：
//   - 老师重置助教密码时的权限边界校验（查此表）
//   - 老师查看自己名下所有助教
// ────────────────────────────────────────────────────────────

model TeacherAssistant {
  /// 助教的一卡通号（PK = 唯一归属保证），FK → users.id（role=assistant）
  assistantUserId String   @id @db.VarChar(10)

  /// 创建该助教账号的老师，FK → users.id（role=teacher）
  teacherUserId   String   @db.VarChar(10)

  createdAt       DateTime @default(now())

  teacher   User @relation("TeacherOwner",   fields: [teacherUserId],   references: [id])
  assistant User @relation("AssistantOwned", fields: [assistantUserId], references: [id])

  @@index([teacherUserId])
  @@map("teacher_assistants")
}

// ────────────────────────────────────────────────────────────
// assistant_bindings — 助教与具体课程的分配关系
//
// 与 teacher_assistants 解耦：
//   teacher_assistants  → "这个助教账号属于哪位老师"（账号创建时写入）
//   assistant_bindings  → "这个助教被分配到了哪门课程"（分配时写入）
//
// 分配前须校验助教确实属于该老师（查 teacher_assistants）。
// 助教账号存在但无分配记录时，登录后不显示任何课程内容（前端处理）。
// 每门课程最多绑定 3 个助教，由业务层校验，不在 DB 层约束。
// ────────────────────────────────────────────────────────────

model AssistantBinding {
  /// 助教的一卡通号，FK → users.id（role=assistant）
  assistantUserId String @db.VarChar(10)

  /// 执行分配操作的老师一卡通号（审计用，无 Prisma relation）
  teacherUserId   String @db.VarChar(10)

  /// 绑定的课程 ID，FK → courses.id
  courseId        BigInt @db.UnsignedBigInt

  createdAt DateTime @default(now())

  assistant User @relation("AssistantUser", fields: [assistantUserId], references: [id])
  course    Course @relation(fields: [courseId], references: [id])

  @@id([assistantUserId, courseId])
  @@index([teacherUserId])
  @@index([courseId])
  @@map("assistant_bindings")
}

// ============================================================
// PHASE 1 — courses / course_teachers / course_members
// 设计文档：docs/api/courses/course-tables-design-v1.md
// ============================================================

enum CourseStatus {
  draft
  active
  archived
}

// ────────────────────────────────────────────────────────────
// courses — 课程基础信息（教务处创建）
// ────────────────────────────────────────────────────────────

model Course {
  id           BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  courseNo     String       @unique @db.VarChar(30)
  name         String       @db.VarChar(80)
  academicYear Int          @db.SmallInt
  semester     Int          @db.TinyInt
  description  String?      @db.Text
  status       CourseStatus @default(draft)

  /// FK → users.id（role=academic），教务处创建人
  createdBy    String       @db.VarChar(10)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  creator          User                @relation(fields: [createdBy], references: [id])
  teachers         CourseTeacher[]
  members          CourseMember[]
  assistantBindings AssistantBinding[]
  assignments      Assignment[]
  stageGrades      StageGrade[]

  @@index([academicYear, semester])
  @@map("courses")
}

// ────────────────────────────────────────────────────────────
// course_teachers — 老师与课程的负责关系（academic 指派）
// ────────────────────────────────────────────────────────────

enum CourseTeacherRole {
  lead // 主讲老师
  co   // 合讲老师
}

model CourseTeacher {
  courseId  BigInt           @db.UnsignedBigInt
  userId    String           @db.VarChar(10)
  role      CourseTeacherRole @default(lead)
  assignedAt DateTime        @default(now())

  course Course @relation(fields: [courseId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([courseId, userId])
  @@map("course_teachers")
}

// ────────────────────────────────────────────────────────────
// course_members — 学生课程成员名单（academic 导入）
// ────────────────────────────────────────────────────────────

enum CourseMemberStatus {
  active
  withdrawn
}

model CourseMember {
  id       BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  courseId BigInt             @db.UnsignedBigInt
  userId   String             @db.VarChar(10)
  status   CourseMemberStatus @default(active)
  joinedAt DateTime           @default(now())

  course Course @relation(fields: [courseId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([courseId, userId])
  @@index([courseId, status])
  @@map("course_members")
}

// ============================================================
// PHASE 2 — assignments / assignment_group_configs / assignment_stages
// ============================================================

enum AssignmentStatus {
  draft
  active
  archived
}

// ────────────────────────────────────────────────────────────
// assignments — 课程项目
// ────────────────────────────────────────────────────────────

model Assignment {
  id               BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  courseId         BigInt           @db.UnsignedBigInt
  title            String           @db.VarChar(120)
  description      String?          @db.Text
  descriptionFiles Json?
  status           AssignmentStatus @default(draft)

  /// FK → users.id（role=teacher）
  createdBy        String           @db.VarChar(10)

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  course       Course                @relation(fields: [courseId], references: [id])
  creator      User                  @relation(fields: [createdBy], references: [id])
  groupConfig  AssignmentGroupConfig?
  stages       AssignmentStage[]
  groups       Group[]
  groupJoinRequests GroupJoinRequest[]
  leaderTransferRequests GroupLeaderTransferRequest[]

  @@map("assignments")
}

// ────────────────────────────────────────────────────────────
// assignment_group_configs — 项目组队规则（1:1，可选）
// ────────────────────────────────────────────────────────────

enum RegroupPolicy {
  teacher_decides
  auto_then_teacher_confirm
}

model AssignmentGroupConfig {
  assignmentId   BigInt         @id @db.UnsignedBigInt
  groupFormStart DateTime?
  groupFormEnd   DateTime?
  groupMinSize   Int            @default(1) @db.UnsignedTinyInt
  groupMaxSize   Int            @default(6) @db.UnsignedTinyInt
  maxGroups      Int?           @db.UnsignedSmallInt
  regroupPolicy  RegroupPolicy  @default(teacher_decides)

  /// FK → users.id（teacher 或 academic），最近修改人
  updatedBy      String         @db.VarChar(10)
  updatedAt      DateTime       @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@map("assignment_group_configs")
}

// ────────────────────────────────────────────────────────────
// assignment_stages — 项目阶段
// ────────────────────────────────────────────────────────────

enum StageStatus {
  planned
  open
  closed
  archived
}

model AssignmentStage {
  id               BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  assignmentId     BigInt      @db.UnsignedBigInt
  stageNo          Int         @db.UnsignedTinyInt
  title            String      @db.VarChar(120)
  description      String?     @db.Text
  startAt          DateTime?
  dueAt            DateTime?
  weight           Decimal?    @db.Decimal(5, 2)
  submissionDesc   String?     @db.Text
  requirementFiles Json?
  acceptCriteria   String?     @db.Text
  status           StageStatus @default(planned)

  /// FK → users.id（role=teacher）
  createdBy        String      @db.VarChar(10)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  assignment Assignment  @relation(fields: [assignmentId], references: [id])
  creator    User        @relation(fields: [createdBy], references: [id])
  miniTasks  MiniTask[]
  submissions Submission[]
  stageGrades StageGrade[]

  @@unique([assignmentId, stageNo])
  @@index([assignmentId, stageNo])
  @@map("assignment_stages")
}

// ============================================================
// PHASE 3 — groups / group_members
// ============================================================

enum GroupStatus {
  forming
  active
  archived
}

// ────────────────────────────────────────────────────────────
// groups — 小组（归属 Assignment）
// ────────────────────────────────────────────────────────────

model Group {
  id           BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  assignmentId BigInt      @db.UnsignedBigInt
  groupNo      Int         @db.UnsignedTinyInt
  name         String?     @db.VarChar(60)
  status       GroupStatus @default(forming)

  /// FK → users.id（role=student），创建小组的学生（初始组长）
  createdBy    String      @db.VarChar(10)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  assignment        Assignment        @relation(fields: [assignmentId], references: [id])
  creator           User              @relation(fields: [createdBy], references: [id])
  members           GroupMember[]
  joinRequests      GroupJoinRequest[]
  leaderTransferRequests GroupLeaderTransferRequest[]
  miniTasks         MiniTask[]
  submissions       Submission[]
  stageGrades       StageGrade[]

  @@unique([assignmentId, groupNo])
  @@map("groups")
}

// ────────────────────────────────────────────────────────────
// group_members — 小组成员
// ────────────────────────────────────────────────────────────

enum GroupMemberRole {
  leader
  member
}

model GroupMember {
  id           BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  groupId      BigInt          @db.UnsignedBigInt
  assignmentId BigInt          @db.UnsignedBigInt
  userId       String          @db.VarChar(10)
  role         GroupMemberRole @default(member)
  joinedAt     DateTime        @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([assignmentId, userId])
  @@index([groupId])
  @@map("group_members")
}

enum GroupJoinRequestStatus {
  pending
  approved
  rejected
  cancelled
  expired
}

model GroupJoinRequest {
  id              BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  assignmentId    BigInt                 @db.UnsignedBigInt
  groupId         BigInt                 @db.UnsignedBigInt
  applicantUserId String                 @db.VarChar(10)
  status          GroupJoinRequestStatus @default(pending)
  reviewedBy      String?                @db.VarChar(10)
  reviewedAt      DateTime?
  reason          String?                @db.VarChar(255)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  group      Group      @relation(fields: [groupId], references: [id])
  applicant  User       @relation("JoinRequestApplicant", fields: [applicantUserId], references: [id])
  reviewer   User?      @relation("JoinRequestReviewer", fields: [reviewedBy], references: [id])

  @@index([groupId, status])
  @@index([assignmentId, applicantUserId, status])
  @@map("group_join_requests")
}

enum GroupLeaderTransferRequestStatus {
  pending
  accepted
  rejected
  cancelled
  expired
}

model GroupLeaderTransferRequest {
  id           BigInt                           @id @default(autoincrement()) @db.UnsignedBigInt
  assignmentId BigInt                           @db.UnsignedBigInt
  groupId      BigInt                           @db.UnsignedBigInt
  fromUserId   String                           @db.VarChar(10)
  toUserId     String                           @db.VarChar(10)
  status       GroupLeaderTransferRequestStatus @default(pending)
  respondedAt  DateTime?
  createdAt    DateTime                         @default(now())
  updatedAt    DateTime                         @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  group      Group      @relation(fields: [groupId], references: [id])
  fromUser   User       @relation("LeaderTransferFrom", fields: [fromUserId], references: [id])
  toUser     User       @relation("LeaderTransferTo", fields: [toUserId], references: [id])

  @@index([groupId, status])
  @@index([assignmentId, fromUserId, status])
  @@map("group_leader_transfer_requests")
}

// ============================================================
// PHASE 4 — mini_tasks / chat_conversations / chat_messages
// ============================================================

enum MiniTaskPriority {
  low
  medium
  high
}

enum MiniTaskStatus {
  todo
  in_progress
  done
  cancelled
}

// ────────────────────────────────────────────────────────────
// mini_tasks — 小组执行任务（可挂靠 Stage）
// ────────────────────────────────────────────────────────────

model MiniTask {
  id          BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  groupId     BigInt          @db.UnsignedBigInt
  stageId     BigInt?         @db.UnsignedBigInt
  title       String          @db.VarChar(120)
  description String?         @db.Text
  assigneeId  String?         @db.VarChar(10)
  assigneeIds Json?
  priority    MiniTaskPriority @default(medium)
  status      MiniTaskStatus  @default(todo)
  dueAt       DateTime?
  reminder1dSentAt DateTime?
  reminder1hSentAt DateTime?
  overdueSentAt DateTime?

  /// FK → users.id，创建人
  createdBy   String          @db.VarChar(10)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  group    Group            @relation(fields: [groupId], references: [id])
  stage    AssignmentStage? @relation(fields: [stageId], references: [id])
  assignee User?            @relation("MiniTaskAssignee", fields: [assigneeId], references: [id])
  creator  User             @relation(fields: [createdBy], references: [id])

  @@index([groupId, stageId])
  @@index([groupId, status])
  @@index([dueAt, status])
  @@index([assigneeId])
  @@map("mini_tasks")
}

// ────────────────────────────────────────────────────────────
// chat_conversations — 统一会话（课程群 + 项目组群）
// ────────────────────────────────────────────────────────────

enum ConversationScopeType {
  course
  group
}

enum ConversationStatus {
  active
  archived
}

model ChatConversation {
  id        BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  scopeType ConversationScopeType
  scopeId   BigInt                 @db.UnsignedBigInt

  /// socket room key: "course:{courseId}" 或 "group:{groupId}"
  roomKey   String                 @unique @db.VarChar(64)

  status    ConversationStatus     @default(active)

  /// 课程群系统自动创建时为 NULL；项目组群为创建学生 ID
  createdBy String?                @db.VarChar(10)

  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  // scopeId 是多态字段（course 或 group），Prisma 不支持同列多态 FK；
  // 应用层根据 scopeType 自行 join courses / groups 表
  creator  User?   @relation(fields: [createdBy], references: [id])
  messages ChatMessage[]
  reads    ChatConversationRead[]

  @@unique([scopeType, scopeId])
  @@map("chat_conversations")
}

// ────────────────────────────────────────────────────────────
// chat_messages — 统一消息（课程群 + 项目组群）
// ────────────────────────────────────────────────────────────

model ChatMessage {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  conversationId BigInt    @db.UnsignedBigInt
  senderId       String    @db.VarChar(10)
  content        String?   @db.Text
  files          Json?
  mentions       Json?
  replyToId      BigInt?   @db.UnsignedBigInt

  /// EventEnvelope.id，幂等键
  eventId        String    @unique @db.VarChar(64)
  traceId        String    @db.VarChar(64)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  editedAt       DateTime?
  deletedAt      DateTime?

  conversation ChatConversation @relation(fields: [conversationId], references: [id])
  sender       User             @relation(fields: [senderId], references: [id])
  replyTo      ChatMessage?     @relation("MessageReply", fields: [replyToId], references: [id])
  replies      ChatMessage[]    @relation("MessageReply")
  filesMeta    ChatFile[]

  @@index([conversationId, createdAt, id])
  @@index([senderId, createdAt])
  @@map("chat_messages")
}

model ChatFile {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  messageId      BigInt   @db.UnsignedBigInt
  objectKey      String   @unique @db.VarChar(255)
  name           String   @db.VarChar(200)
  size           BigInt   @db.UnsignedBigInt
  mimeType       String   @db.VarChar(120)
  uploadedAt     DateTime
  expiresAt      DateTime
  thumbnailKey   String?  @db.VarChar(255)

  message ChatMessage @relation(fields: [messageId], references: [id])

  @@index([messageId])
  @@index([expiresAt])
  @@map("chat_files")
}

model ChatConversationRead {
  conversationId BigInt   @db.UnsignedBigInt
  userId         String   @db.VarChar(10)
  lastMessageId  BigInt?
  lastReadAt     DateTime?
  updatedAt      DateTime @updatedAt

  conversation ChatConversation @relation(fields: [conversationId], references: [id])
  user         User             @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
  @@index([userId, lastReadAt])
  @@map("chat_conversation_reads")
}

// ============================================================
// PHASE 5 — submissions / submission_files / reviews
// ============================================================

enum SubmissionStatus {
  draft
  not_submitted
  submitted
  under_review
  needs_changes
  reviewed
  approved
  rejected
}

enum ReviewStatus {
  draft
  submitted
}

enum ReviewDecision {
  approved
  needs_changes
  rejected
}

model Submission {
  id         BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  groupId    BigInt          @db.UnsignedBigInt
  stageId    BigInt          @db.UnsignedBigInt
  attemptNo  Int             @db.UnsignedSmallInt
  status     SubmissionStatus @default(draft)
  summary    String?         @db.Text
  payload    Json?
  submittedAt DateTime?
  createdBy  String          @db.VarChar(10)
  submittedBy String?        @db.VarChar(10)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  group     Group           @relation(fields: [groupId], references: [id])
  stage     AssignmentStage @relation(fields: [stageId], references: [id])
  creator   User            @relation("SubmissionCreator", fields: [createdBy], references: [id])
  submitter User?           @relation("SubmissionSubmitter", fields: [submittedBy], references: [id])
  files     SubmissionFile[]
  reviews   Review[]
  grade     StageGrade?

  @@unique([groupId, stageId, attemptNo])
  @@index([groupId, stageId, status])
  @@index([stageId, status])
  @@index([submittedAt])
  @@map("submissions")
}

model SubmissionFile {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  submissionId BigInt   @db.UnsignedBigInt
  objectKey    String   @unique @db.VarChar(255)
  name         String   @db.VarChar(200)
  size         BigInt   @db.UnsignedBigInt
  mimeType     String   @db.VarChar(120)
  slotKey      String?  @db.VarChar(60)
  uploadedBy   String   @db.VarChar(10)
  uploadedAt   DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])
  uploader   User       @relation("SubmissionUploader", fields: [uploadedBy], references: [id])

  @@index([submissionId])
  @@index([uploadedBy, uploadedAt])
  @@map("submission_files")
}

model Review {
  id           BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  submissionId BigInt        @db.UnsignedBigInt
  reviewerId   String        @db.VarChar(10)
  status       ReviewStatus  @default(draft)
  decision     ReviewDecision?
  score        Decimal?      @db.Decimal(6, 2)
  rubric       Json?
  comment      String?       @db.Text
  submittedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id])
  reviewer   User       @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  sourceGrades StageGrade[] @relation("StageGradeSourceReview")

  @@unique([submissionId, reviewerId])
  @@index([submissionId, status])
  @@index([reviewerId, createdAt])
  @@map("reviews")
}

enum GradeStatus {
  draft
  published
}

enum GradeAction {
  created
  updated
  published
  adjusted
}

model StageGrade {
  id             BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  submissionId   BigInt      @unique @db.UnsignedBigInt
  groupId        BigInt      @db.UnsignedBigInt
  stageId        BigInt      @db.UnsignedBigInt
  courseId       BigInt      @db.UnsignedBigInt
  score          Decimal?    @db.Decimal(6, 2)
  status         GradeStatus @default(draft)
  graderId       String      @db.VarChar(10)
  publishedBy    String?     @db.VarChar(10)
  publishedAt    DateTime?
  sourceReviewId BigInt?     @db.UnsignedBigInt
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  submission   Submission     @relation(fields: [submissionId], references: [id])
  group        Group          @relation(fields: [groupId], references: [id])
  stage        AssignmentStage @relation(fields: [stageId], references: [id])
  course       Course         @relation(fields: [courseId], references: [id])
  grader       User           @relation("StageGradeGrader", fields: [graderId], references: [id])
  publisher    User?          @relation("StageGradePublisher", fields: [publishedBy], references: [id])
  sourceReview Review?        @relation("StageGradeSourceReview", fields: [sourceReviewId], references: [id])
  logs         StageGradeLog[]

  @@index([courseId, stageId, status])
  @@index([groupId, stageId])
  @@map("stage_grades")
}

model StageGradeLog {
  id           BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  stageGradeId BigInt      @db.UnsignedBigInt
  action       GradeAction
  beforeScore  Decimal?    @db.Decimal(6, 2)
  afterScore   Decimal?    @db.Decimal(6, 2)
  operatorId   String      @db.VarChar(10)
  reason       String?     @db.VarChar(500)
  createdAt    DateTime    @default(now())

  stageGrade StageGrade @relation(fields: [stageGradeId], references: [id])
  operator   User       @relation("StageGradeLogOperator", fields: [operatorId], references: [id])

  @@index([stageGradeId, createdAt])
  @@index([operatorId, createdAt])
  @@map("stage_grade_logs")
}
